          <p class="text-xs text-[#6B7280] mt-1">System Active</p>
        </a>

        <a href="/colors/blue/" class="group bg-white border border-[#E5E7EB] rounded-xl p-6 flex flex-col items-center text-center hover:border-[#3B82F6] hover:shadow-md transition-all cursor-pointer block">

---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Car Dashboard Warning Light Meanings Explained | WarningLightMeaning.com"
  description="Instantly understand any car dashboard warning light. Every symbol explained clearly — what it means, if it's safe to drive, and exactly what to do."
  canonical="https://warninglightmeaning.com/"
>
  <!-- SECTION 1: HERO -->
  <section class="w-full bg-white text-center py-20 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="text-xs font-semibold uppercase tracking-widest text-[#F59E0B] mb-4">
        FREE &middot; ALL CAR MAKES &middot; UPDATED 2025
      </div>
      <h1 class="text-5xl font-bold text-[#1A1A1A] leading-tight max-w-3xl mx-auto mb-6">
        What Does That Warning Light Mean?
      </h1>
      <p class="text-lg text-[#6B7280] max-w-2xl mx-auto mb-10">
        Every dashboard symbol explained in plain English — so you know exactly what to do, right now.
      </p>
      
      <div class="max-w-2xl mx-auto">
        <div class="flex items-center border-2 border-[#F59E0B] rounded-full px-4 py-3 bg-white shadow-sm focus-within:ring-2 focus-within:ring-[#F59E0B] focus-within:ring-opacity-50 transition-all">
          <svg class="w-5 h-5 text-[#6B7280]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          <input type="text" placeholder="Search a warning light or car make..." class="flex-1 outline-none text-base px-3 placeholder-[#9CA3AF]" />
          <button class="bg-[#F59E0B] text-white font-semibold px-6 py-2 rounded-full hover:bg-[#D97706] transition-colors">
            Search
          </button>
        </div>
      </div>
      
      <div class="text-center mt-4 text-sm text-[#6B7280] flex items-center justify-center gap-2 flex-wrap">
        <span>Popular:</span>
        <a href="/lights/check-engine/" class="hover:text-[#F59E0B] transition-colors">Check Engine</a> &middot;
        <a href="/lights/tire-pressure/" class="hover:text-[#F59E0B] transition-colors">Tire Pressure</a> &middot;
        <a href="/lights/battery/" class="hover:text-[#F59E0B] transition-colors">Battery</a> &middot;
        <a href="/lights/abs/" class="hover:text-[#F59E0B] transition-colors">ABS</a> &middot;
        <a href="/lights/airbag/" class="hover:text-[#F59E0B] transition-colors">Airbag</a>
      </div>
    </div>
  </section>

  <!-- SECTION 2: BROWSE BY LIGHT COLOR -->
  <section class="bg-white py-16 border-t border-[#E5E7EB] px-6">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-[#6B7280] mb-8 text-center">
        BROWSE BY LIGHT COLOR
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        
        <a href="/colors/red/" class="group bg-white border border-[#E5E7EB] rounded-xl p-6 flex flex-col items-center text-center hover:border-[#EF4444] hover:shadow-md transition-all cursor-pointer block">
          <div class="w-16 h-16 rounded-full mx-auto mb-4 bg-[#EF4444]"></div>
          <h3 class="font-semibold text-[#1A1A1A] text-sm group-hover:text-[#EF4444] transition-colors">Red</h3>
          <p class="text-xs text-[#6B7280] mt-1">Stop Immediately</p>
        </a>

        <a href="/colors/amber/" class="group bg-white border border-[#E5E7EB] rounded-xl p-6 flex flex-col items-center text-center hover:border-[#F59E0B] hover:shadow-md transition-all cursor-pointer block">

---
import Layout from '../../../layouts/Layout.astro';
import LightCard from '../../../components/LightCard.astro';
import AdUnit from '../../../components/AdUnit.astro';
import { lights } from '../../../data/lights';

import { makes, makeSlug } from '../../../data/makes';

export function getStaticPaths() {
  return makes.map(make => ({
    params: { make: makeSlug(make) },
    props: { makeName: make }
  }));
}

const { makeName } = Astro.props;
const makeLights = lights.filter(l => l.makes.includes(makeName));

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://warninglightmeaning.com/" },
    { "@type": "ListItem", "position": 2, "name": "Car Makes", "item": "https://warninglightmeaning.com/makes/" },
    { "@type": "ListItem", "position": 3, "name": makeName, "item": `https://warninglightmeaning.com/makes/${makeSlug(makeName)}/` }
  ]
};

const title = `${makeName} Dashboard Warning Lights Explained | WarningLightMeaning.com`;
const description = `Every ${makeName} dashboard warning light explained clearly. Find out what each symbol means, urgency level, and what to do next.`;
---

<Layout title={title} description={description}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <nav class="max-w-5xl mx-auto px-4 pt-6 pb-2 text-sm text-gray-500">
    <ol class="flex items-center gap-2">
      <li><a href="/" class="hover:text-amber-600">Home</a></li>
      <li>/</li>
      <li><a href="/makes/" class="hover:text-amber-600">Car Makes</a></li>
      <li>/</li>
      <li class="text-gray-900 font-medium">{makeName}</li>
    </ol>
  </nav>

  <main class="max-w-5xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">{makeName} Dashboard Warning Lights</h1>
    <p class="text-gray-600 mb-8 text-lg">All dashboard warning lights for {makeName} vehicles — explained clearly with urgency levels and step-by-step guidance.</p>

    <AdUnit />

    <div class="grid sm:grid-cols-2 gap-4 mt-6">
      {makeLights.map(light => (
        <LightCard
          slug={light.slug}
          name={light.name}
          color={light.color}
          urgency={light.urgency}
          symbol={light.symbol}
          shortDesc={light.shortDesc}
        />
      ))}
    </div>
  </main>
</Layout>

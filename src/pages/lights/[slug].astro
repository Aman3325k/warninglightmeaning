---
import Layout from '../../layouts/Layout.astro';
import UrgencyBadge from '../../components/UrgencyBadge.astro';
import AdUnit from '../../components/AdUnit.astro';
import { lights } from '../../data/lights';

export function getStaticPaths() {
  return lights.map((light) => ({
    params: { slug: light.slug },
    props: { light },
  }));
}

const { light } = Astro.props;

const lightColor: Record<string, string> = {
  Red: '#EF4444',
  Amber: '#F59E0B',
  White: '#F9FAFB',
  Blue: '#3B82F6',
  Green: '#22C55E',
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `Is it safe to drive with the ${light.name} on?`,
      "acceptedAnswer": { "@type": "Answer", "text": light.safeToDrive }
    },
    {
      "@type": "Question",
      "name": `What causes the ${light.name} to come on?`,
      "acceptedAnswer": { "@type": "Answer", "text": light.causes.join(', ') }
    },
    {
      "@type": "Question",
      "name": `How much does it cost to fix the ${light.name}?`,
      "acceptedAnswer": { "@type": "Answer", "text": light.estimatedCost }
    },
    {
      "@type": "Question",
      "name": `Can I reset the ${light.name} myself?`,
      "acceptedAnswer": { "@type": "Answer", "text": light.resetInstructions }
    },
    {
      "@type": "Question",
      "name": `How long can I drive with the ${light.name} on?`,
      "acceptedAnswer": { "@type": "Answer", "text": light.howLongCanDrive }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://warninglightmeaning.com/" },
    { "@type": "ListItem", "position": 2, "name": "Warning Lights", "item": "https://warninglightmeaning.com/warning-lights/" },
    { "@type": "ListItem", "position": 3, "name": light.name, "item": `https://warninglightmeaning.com/lights/${light.slug}/` }
  ]
};

const title = `${light.name} — What It Means & What To Do | WarningLightMeaning.com`;
const description = `See the ${light.name} on your dashboard? Find out what it means, if it's safe to drive, and exactly what to do — explained clearly for all car makes.`;
---

<Layout title={title} description={description}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <nav class="max-w-4xl mx-auto px-4 pt-6 pb-2 text-sm text-gray-500">
    <ol class="flex items-center gap-2">
      <li><a href="/" class="hover:text-amber-600">Home</a></li>
      <li>/</li>
      <li><a href="/warning-lights/" class="hover:text-amber-600">Warning Lights</a></li>
      <li>/</li>
      <li class="text-gray-900 font-medium truncate">{light.name}</li>
    </ol>
  </nav>

  <main class="max-w-4xl mx-auto px-4 py-8">
    <div class="lg:grid lg:grid-cols-3 lg:gap-8">

      <div class="lg:col-span-2">

        <div class="bg-white border border-gray-200 rounded-2xl p-6 mb-6">
          <div class="flex items-center gap-4 mb-4">
            <div
              class="w-16 h-16 rounded-full flex items-center justify-center text-3xl flex-shrink-0"
              style={`background-color: ${lightColor[light.color] || '#F59E0B'}`}
            >
              {light.symbol}
            </div>
            <div>
              <h1 class="text-2xl font-bold text-gray-900 leading-tight">{light.name}</h1>
              <div class="mt-2">
                <UrgencyBadge urgency={light.urgency} />
              </div>
            </div>
          </div>
          <p class="text-gray-700 text-base leading-relaxed">{light.fullDesc}</p>
        </div>

        <AdUnit />

        <div class="bg-white border border-gray-200 rounded-2xl p-6 mb-6">
          <h2 class="text-xl font-bold text-gray-900 mb-3">Is It Safe to Drive?</h2>
          <p class="text-gray-700 leading-relaxed">{light.safeToDrive}</p>
        </div>

        <div class="bg-white border border-gray-200 rounded-2xl p-6 mb-6">
          <h2 class="text-xl font-bold text-gray-900 mb-4">Common Causes</h2>
          <ul class="space-y-2">
            {light.causes.map((cause) => (
              <li class="flex items-start gap-2 text-gray-700">
                <span class="text-amber-500 mt-0.5 flex-shrink-0">▸</span>
                {cause}
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6 mb-6">
          <h2 class="text-xl font-bold text-gray-900 mb-4">What To Do</h2>
          <ol class="space-y-3">
            {light.whatToDo.map((step, i) => (
              <li class="flex items-start gap-3 text-gray-800">
                <span class="w-6 h-6 rounded-full bg-amber-400 text-gray-900 font-bold text-sm flex items-center justify-center flex-shrink-0 mt-0.5">{i + 1}</span>
                {step}
              </li>
            ))}
          </ol>
        </div>

        <AdUnit />

        <div class="grid sm:grid-cols-2 gap-4 mb-6">
          <div class="bg-white border border-gray-200 rounded-2xl p-5">
            <h2 class="text-lg font-bold text-gray-900 mb-2">Estimated Repair Cost</h2>
            <p class="text-gray-700 text-sm leading-relaxed">{light.estimatedCost}</p>
          </div>
          <div class="bg-white border border-gray-200 rounded-2xl p-5">
            <h2 class="text-lg font-bold text-gray-900 mb-2">How Long Can You Drive?</h2>
            <p class="text-gray-700 text-sm leading-relaxed">{light.howLongCanDrive}</p>
          </div>
        </div>

        <div class="bg-white border border-gray-200 rounded-2xl p-6 mb-6">
          <h2 class="text-xl font-bold text-gray-900 mb-3">
            Can You Reset It Yourself?
            <span class={`ml-2 text-sm font-normal px-2 py-0.5 rounded-full ${light.canResetYourself ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>
              {light.canResetYourself ? 'Yes' : 'No'}
            </span>
          </h2>
          <p class="text-gray-700 leading-relaxed">{light.resetInstructions}</p>
        </div>

        <div class="bg-white border border-gray-200 rounded-2xl p-6 mb-6">
          <h2 class="text-xl font-bold text-gray-900 mb-5">Frequently Asked Questions</h2>
          <div class="space-y-5">
            <div>
              <h3 class="font-semibold text-gray-900 mb-1">Is it safe to drive with the {light.name} on?</h3>
              <p class="text-gray-700 text-sm leading-relaxed">{light.safeToDrive}</p>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-1">What causes the {light.name} to come on?</h3>
              <p class="text-gray-700 text-sm leading-relaxed">{light.causes.join(', ')}.</p>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-1">How much does it cost to fix?</h3>
              <p class="text-gray-700 text-sm leading-relaxed">{light.estimatedCost}</p>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-1">Can I reset the {light.name} myself?</h3>
              <p class="text-gray-700 text-sm leading-relaxed">{light.resetInstructions}</p>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-1">How long can I drive with the {light.name} on?</h3>
              <p class="text-gray-700 text-sm leading-relaxed">{light.howLongCanDrive}</p>
            </div>
          </div>
        </div>

      </div>

      <aside class="hidden lg:block">
        <div class="sticky top-6 space-y-4">
          <AdUnit format="rectangle" />
          <div class="bg-white border border-gray-200 rounded-2xl p-5">
            <h3 class="font-bold text-gray-900 mb-3 text-sm uppercase tracking-wide">All Warning Lights</h3>
            <a href="/warning-lights/" class="block text-amber-600 hover:text-amber-700 text-sm font-medium">Browse All Lights →</a>
          </div>
          <div class="bg-white border border-gray-200 rounded-2xl p-5">
            <h3 class="font-bold text-gray-900 mb-3 text-sm uppercase tracking-wide">Browse by Car Make</h3>
            <a href="/makes/" class="block text-amber-600 hover:text-amber-700 text-sm font-medium">All Car Makes →</a>
          </div>
        </div>
      </aside>

    </div>
  </main>
</Layout>

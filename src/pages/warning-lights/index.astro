---
import Layout from '../../layouts/Layout.astro';
import LightCard from '../../components/LightCard.astro';
import AdUnit from '../../components/AdUnit.astro';
import { lights } from '../../data/lights';

const stopImmediately = lights.filter(l => l.urgency === 'Stop Immediately');
const checkSoon = lights.filter(l => l.urgency === 'Check Soon' || l.urgency === 'Stop Soon');
const infoOnly = lights.filter(l => l.urgency === 'Info Only');

const title = 'Dashboard Warning Lights Explained | WarningLightMeaning.com';
const description = 'Every dashboard warning light explained clearly. Find out what each symbol means, how urgent it is, and exactly what to do next.';
---

<Layout title={title} description={description}>
  <main class="max-w-5xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Dashboard Warning Lights Explained</h1>
    <p class="text-gray-600 mb-8 text-lg">Find your warning light below. Click any light to see what it means and what to do.</p>

    <AdUnit />

    {stopImmediately.length > 0 && (
      <section class="mb-10">
        <h2 class="text-xl font-bold text-red-600 mb-4 flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-red-500 inline-block"></span>
          Stop Immediately
        </h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {stopImmediately.map(light => (
            <LightCard
              slug={light.slug}
              name={light.name}
              color={light.color}
              urgency={light.urgency}
              symbol={light.symbol}
              shortDesc={light.shortDesc}
            />
          ))}
        </div>
      </section>
    )}

    {checkSoon.length > 0 && (
      <section class="mb-10">
        <h2 class="text-xl font-bold text-amber-600 mb-4 flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-amber-400 inline-block"></span>
          Check Soon
        </h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {checkSoon.map(light => (
            <LightCard
              slug={light.slug}
              name={light.name}
              color={light.color}
              urgency={light.urgency}
              symbol={light.symbol}
              shortDesc={light.shortDesc}
            />
          ))}
        </div>
      </section>
    )}

    {infoOnly.length > 0 && (
      <section class="mb-10">
        <h2 class="text-xl font-bold text-gray-500 mb-4 flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-gray-400 inline-block"></span>
          Info Only
        </h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {infoOnly.map(light => (
            <LightCard
              slug={light.slug}
              name={light.name}
              color={light.color}
              urgency={light.urgency}
              symbol={light.symbol}
              shortDesc={light.shortDesc}
            />
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>

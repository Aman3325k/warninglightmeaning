---
import Layout from '../../../layouts/Layout.astro';
import LightCard from '../../../components/LightCard.astro';
import AdUnit from '../../../components/AdUnit.astro';
import { lights } from '../../../data/lights';

export function getStaticPaths() {
  const colors = ['Red', 'Amber', 'Yellow', 'Green', 'Blue', 'White'];
  return colors.map(color => ({
    params: { color: color.toLowerCase() },
    props: { colorName: color }
  }));
}

const { colorName } = Astro.props;

// Many people search for "Yellow" when the industry term is "Amber"
const targetColor = colorName === 'Yellow' ? 'Amber' : colorName;

const colorLights = lights.filter(l => l.color.toLowerCase() === targetColor.toLowerCase());

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://warninglightmeaning.com/" },
    { "@type": "ListItem", "position": 2, "name": `${colorName} Warning Lights`, "item": `https://warninglightmeaning.com/colors/${colorName.toLowerCase()}/` }
  ]
};

const title = `${colorName} Dashboard Warning Lights Explained | WarningLightMeaning.com`;
const description = `What do ${colorName.toLowerCase()} dashboard warning lights mean? Find out urgency levels, safety info, and what to do next.`;
---

<Layout title={title} description={description}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <nav class="max-w-5xl mx-auto px-4 pt-6 pb-2 text-sm text-gray-500">
    <ol class="flex items-center gap-2">
      <li><a href="/" class="hover:text-amber-600">Home</a></li>
      <li>/</li>
      <li class="text-gray-900 font-medium">{colorName} Lights</li>
    </ol>
  </nav>

  <main class="max-w-5xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">{colorName} Dashboard Warning Lights</h1>
    <p class="text-gray-600 mb-8 text-lg">All {colorName.toLowerCase()} dashboard warning lights explained clearly with urgency levels and step-by-step guidance.</p>

    <AdUnit />

    {colorLights.length > 0 ? (
      <div class="grid sm:grid-cols-2 gap-4 mt-6">
        {colorLights.map(light => (
          <LightCard
            slug={light.slug}
            name={light.name}
            color={light.color}
            urgency={light.urgency}
            symbol={light.symbol}
            shortDesc={light.shortDesc}
          />
        ))}
      </div>
    ) : (
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-8 text-center text-gray-500 mt-6">
        No {colorName.toLowerCase()} warning lights found in our database currently.
      </div>
    )}
  </main>
</Layout>

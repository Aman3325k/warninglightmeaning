---
import UrgencyBadge from './UrgencyBadge.astro';
interface Props {
  slug: string;
  name: string;
  color: string;
  urgency: 'Stop Immediately' | 'Stop Soon' | 'Check Soon' | 'Info Only';
  symbol: string;
  shortDesc: string;
}
const { slug, name, color, urgency, symbol, shortDesc } = Astro.props;

const colorMap: Record<string, string> = {
  Red: 'bg-red-500',
  Amber: 'bg-amber-400',
  White: 'bg-gray-100 border border-gray-300',
  Blue: 'bg-blue-500',
  Green: 'bg-green-500',
};
const dotColor = colorMap[color] || 'bg-gray-400';
---
<a href={`/lights/${slug}/`} class="block bg-white border border-gray-200 rounded-xl p-5 hover:shadow-md hover:border-amber-400 transition-all group">
  <div class="flex items-start gap-4">
    <div class={`w-12 h-12 rounded-full flex items-center justify-center text-xl flex-shrink-0 ${dotColor}`}>
      {symbol}
    </div>
    <div class="flex-1 min-w-0">
      <h3 class="font-semibold text-gray-900 group-hover:text-amber-600 transition-colors text-base leading-tight mb-1">{name}</h3>
      <p class="text-gray-500 text-sm leading-snug mb-3 line-clamp-2">{shortDesc}</p>
      <UrgencyBadge urgency={urgency} />
    </div>
  </div>
</a>
